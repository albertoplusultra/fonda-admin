{
  "version": 2,
  "functions": {
    "api/index.js": {
      "maxDuration": 300
    }
  },
  "crons": [
    {
      "path": "/api/cron/scrape",
      "schedule": "0 5 * * *"
    }
  ],
  "rewrites": [
    {
      "source": "/static/(.*)",
      "destination": "/api/index.js"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/index.js"
    },
    {
      "source": "/",
      "destination": "/api/index.js"
    }
  ]
}
