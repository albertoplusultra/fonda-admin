# Google OAuth 2.0
# Obtén estas credenciales en: https://console.cloud.google.com → APIs → Credenciales
GOOGLE_CLIENT_ID=tu_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=tu_client_secret

# Secreto para firmar las cookies de sesión JWT
# Genera uno con: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=cambia_esto_por_una_cadena_aleatoria_larga

# URL base del servidor (sin barra final)
# En desarrollo: http://localhost:8000
# En producción: https://tudominio.com
BASE_URL=http://localhost:8000

# ── Opiniones (scraping de reseñas) ──────────────────────────────────────────
# URL de la página de reseñas de tu hotel en Booking.com
# Ej: https://www.booking.com/hotel/es/nombre-del-hotel.es.html
BOOKING_REVIEWS_URL=

# URL de tu hotel en Google Maps (la URL completa del navegador)
# Ej: https://www.google.com/maps/place/Fonda+de+los+Pr%C3%ADncipes/...
GOOGLE_REVIEWS_URL=

# URL de la página de reseñas de tu hotel en TripAdvisor
# Ej: https://www.tripadvisor.es/Hotel_Review-g187496-d1234567-Reviews-Nombre.html
TRIPADVISOR_REVIEWS_URL=
